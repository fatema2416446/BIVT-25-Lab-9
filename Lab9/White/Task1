namespace Lab9 {
public class Task1 : White
  {
      private double _output;

      public double Output => _output;

      public Task1(string text) : base(text)
      {
          _output = 0.0;
      }

      public override void Review()
      {
          string text = Input;
          if (string.IsNullOrEmpty(text))
          {
              _output = 0.0;
              return;
          }

          List<string> sentences = new List<string>();
          StringBuilder currentSentence = new StringBuilder();

          for (int i = 0; i < text.Length; i++)
          {
              char c = text[i];
              currentSentence.Append(c);
              if (c == '.' || c == '!' || c == '?')
              {
                  sentences.Add(currentSentence.ToString());
                  currentSentence.Clear();
              }
          }
          
          if (currentSentence.Length > 0)
              sentences.Add(currentSentence.ToString());

          if (sentences.Count == 0)
          {
              _output = 0.0;
              return;
          }

          double totalComplexity = 0.0;
          foreach (string sentence in sentences)
          {
              int wordCount = 0;
              int punctuationCount = 0;
              bool inWord = false;

              for (int i = 0; i < sentence.Length; i++)
              {
                  char c = sentence[i];
                  bool isSeparator = Char.IsSeparator(c) && c != '\u2028' && c != '\u2029';
                  bool isPunctuation = Char.IsPunctuation(c);

                  if (isSeparator)
                  {
                      if (inWord) inWord = false;
                  }
                  else if (Char.IsLetter(c) || c == '-' || c == '`')
                  {
                      if (!inWord)
                      {
                          inWord = true;
                          wordCount++;
                      }
                  }
                  else
                  {
                      if (inWord) inWord = false;
                  }

                  if (isPunctuation)
                      punctuationCount++;
              }

              totalComplexity += wordCount + punctuationCount;
          }

          _output = totalComplexity / sentences.Count;
      }

      public override string ToString()
      {
          return _output.ToString(CultureInfo.InvariantCulture);
      }
  }
}
